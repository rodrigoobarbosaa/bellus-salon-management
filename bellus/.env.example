# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Twilio — WhatsApp/SMS notifications
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
# WhatsApp sender — use Twilio sandbox for testing: whatsapp:+14155238886
# For production: your approved WhatsApp Business number
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# SMS sender (optional fallback) — your Twilio phone number
TWILIO_SMS_FROM=+14155238886

# App
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_APP_NAME=Bellus

# Cron protection — any random string, set same in Vercel env vars
CRON_SECRET=your-random-secret-here
