# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Evolution API — WhatsApp via WebSocket bridge
# Mantém o WhatsApp Business no celular funcionando normalmente
EVOLUTION_API_URL=https://your-evolution-api.up.railway.app
EVOLUTION_API_KEY=your-global-api-key
EVOLUTION_INSTANCE_NAME=Bellus
EVOLUTION_INSTANCE_TOKEN=your-instance-token

# Anthropic — Claude API (chatbot conversacional + marketing)
ANTHROPIC_API_KEY=your-anthropic-api-key

# App
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_APP_NAME=Bellus

# Cron protection — any random string, set same in Vercel env vars
CRON_SECRET=your-random-secret-here
