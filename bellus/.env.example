# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Meta Cloud API — WhatsApp + Instagram
# Get from: https://developers.facebook.com/apps → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-permanent-access-token
META_APP_SECRET=your-app-secret
META_WEBHOOK_VERIFY_TOKEN=your-random-verify-token

# Anthropic — Claude API (chatbot conversacional + marketing)
ANTHROPIC_API_KEY=your-anthropic-api-key

# App
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_APP_NAME=Bellus

# Cron protection — any random string, set same in Vercel env vars
CRON_SECRET=your-random-secret-here
